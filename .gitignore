prd/01-需求调研/成员分析/

# 临时文件目录（保留目录,忽略内容）
tmp/*
!tmp/.gitkeep

# ===== 德塔（NDO）游戏模块 =====
# game-server/.env 各机器独立配置（已在上方 .env 规则中忽略）
# 游戏资源（保留目录结构，忽略大文件）
public/game/audio/**/*
!public/game/audio/**/.gitkeep
# 游戏美术资源（PNG/JPG）直接入库，走 GitHub 部署链路
# 原因：黑机无法直连服务器，PNG 必须随代码一起 push 才能部署到服务器
# 总量约 1-2MB，不会导致仓库膨胀
askpass.bat

# CC0 素材包原始下载（解压后的源文件，不入库，只保留切片）
.ai/asset-staging/

# Playwright MCP 临时截图/快照
.playwright-mcp/
