# 日志文件
logs/
*.log

# 临时文件
*.tmp
*.swp
*~

# 编辑器配置
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 系统文件
.DS_Store
Thumbs.db

# 依赖目录
node_modules/
vendor/

# 环境变量
.env
.env.local

# 编译输出
dist/
build/

# 数据库文件
*.db
*.db-journal

# 媒体文件（保留目录结构，忽略实际文件）
public/media/**/*
!public/media/**/.gitkeep
!public/media/**/README.md

# pnpm standalone bundle（npm 11 bug 临时方案）
package/
pnpm.tgz

# ===== AI 跨机协作（详见 prd/05-开发规范/ai-collab.md）=====
# 以下为项目级共享，纳入 git 跟踪：
#   .trae/.rules/     - AI 规则集
#   .trae/.skills/    - AI 技能库
#   .ai/handoff.md   - AI 交接文件
# 以下为个人级，不跟踪：
#   .trae/*（除 .rules/.skills 外）- IDE 个人状态
#   .ai/local/       - AI 本地状态（各机器独立）

# Trae IDE — 共享规则和技能，忽略其余个人状态
.trae/*
!.trae/.rules/
!.trae/.skills/

# AI 本地状态（各机器独立，不跟踪）
.ai/local/

# 成员分析报告(含真实聊天记录分析,敏感,不跟踪)
prd/01-需求调研/成员分析/

# 临时文件目录（保留目录,忽略内容）
tmp/*
!tmp/.gitkeep

# ===== 德塔（NDO）游戏模块 =====
# game-server/.env 各机器独立配置（已在上方 .env 规则中忽略）
# 游戏资源（保留目录结构，忽略大文件）
public/game/audio/**/*
!public/game/audio/**/.gitkeep
