generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  passwordHash String
  nickname     String?
  avatar       String?
  skinId       String?   // 玩家形象 ID（'1'-'5'），null = 未选择
  role         String    @default("member") // super_admin | admin | member
  status       String    @default("active") // active | disabled
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  createdCodes   InviteCode[]  @relation("CodeCreator")
  usedCodes      InviteCode[]  @relation("CodeUser")
  importBatches  ImportBatch[] @relation("BatchImporter")
  chatSessions   ChatSession[] @relation("ChatOwner")
  posts          Post[]        @relation("PostAuthor")
  comments       Comment[]     @relation("CommentAuthor")
  likes          Like[]        @relation("PostLiker")

  @@map("users")
}

// ===== 男德墙 =====

model Post {
  id        Int      @id @default(autoincrement())
  authorId  Int
  content   String   // 文字内容（最长 500 字）
  image     String?  // 图片路径（/uploads/wall/xxx.jpg）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]

  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  content   String   // 评论内容
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model Like {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostLiker", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId]) // 一人一帖一赞
  @@map("likes")
}

model InviteCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  createdBy Int
  usedBy    Int?
  status    String    @default("unused") // unused | used | expired
  expiresAt DateTime
  createdAt DateTime  @default(now())

  creator User  @relation("CodeCreator", fields: [createdBy], references: [id])
  user    User? @relation("CodeUser", fields: [usedBy], references: [id])

  @@map("invite_codes")
}

model Announcement {
  id        Int       @id @default(1)
  content   String    @default("欢迎来到男德学院")
  updatedAt DateTime  @updatedAt

  @@map("announcements")
}

model Version {
  id        Int      @id @default(autoincrement())
  version   String   @unique // "v1.1.0"
  date      DateTime // 发版日期
  summary   String   @default("") // 公告栏摘要（一句话）
  updates   String   @default("[]") // 本次更新（JSON 数组）
  plans     String   @default("[]") // 未来规划（JSON 数组）
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("versions")
}

// ===== AI 助手 =====

model ImportBatch {
  id         Int      @id @default(autoincrement())
  filename   String
  importedBy Int
  count      Int
  skipped    Int
  createdAt  DateTime @default(now())

  user     User           @relation("BatchImporter", fields: [importedBy], references: [id])
  messages GroupMessage[]

  @@map("import_batches")
}

model GroupMessage {
  id        Int      @id @default(autoincrement())
  batchId   Int
  talker    String
  nickname  String?
  content   String
  msgTime   DateTime
  type      String   @default("text")
  createdAt DateTime @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([talker, msgTime])
  @@index([talker])
  @@index([msgTime])
  @@map("group_messages")
}

model ChatSession {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation("ChatOwner", fields: [userId], references: [id])
  turns ChatTurn[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatTurn {
  id        Int      @id @default(autoincrement())
  sessionId Int
  role      String   // user | assistant
  content   String
  intent    String?  // statistic | semantic | chat（仅 assistant）
  sources   String?  // JSON 字符串，引用来源
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("chat_turns")
}

// ===== 语义检索：消息分块 + 提示词 =====

model MessageChunk {
  id           Int      @id @default(autoincrement())
  startMsgId   Int      // 起始消息 ID
  endMsgId     Int      // 结束消息 ID
  chunkDate    String?  // 日期（YYYY-MM-DD）
  keywords     String   // 关键提示词（LLM 生成）
  summary      String?  // 简要摘要
  participants String?  // 参与者
  msgCount     Int      // 消息数
  createdAt    DateTime @default(now())

  @@index([chunkDate])
  @@map("message_chunks")
}
