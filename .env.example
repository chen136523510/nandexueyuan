# 环境变量说明
# 此文件为模板，提交到 git。实际 .env 不提交。
# 复制此文件为 .env 并填入实际值。

# ===== 运行环境 =====
# development | production
NODE_ENV=development

# ===== 前端 =====
# Vite 开发服务器端口
VITE_PORT=5173
# API 基础路径（开发环境走 vite proxy，生产环境走 Nginx）
VITE_API_BASE=/api

# ===== 后端 =====
# 后端监听端口
PORT=3000
# JWT 密钥（生产环境务必更换为随机长串）
JWT_SECRET=change-me-in-production
# JWT 过期时间
JWT_EXPIRES=7d

# ===== 数据库 =====
# SQLite 文件路径
DATABASE_URL=file:./dev.db

# ===== 服务器（仅生产环境）=====
SERVER_HOST=47.96.158.104
SERVER_USER=root
SERVER_SSH_PORT=22
SERVER_SSH_ALIAS=nandexueyuan
# 项目路径
SERVER_DEPLOY_DIR=/root/projects/www.nandexueyuan.top
SERVER_BARE_REPO=/root/projects/www.nandexueyuan.top.git
# 宝塔面板
SERVER_BT_PANEL=https://47.96.158.104:8888/4de8a5ad

# ===== 域名 =====
DOMAIN=nandexueyuan.top
DOMAIN_WWW=www.nandexueyuan.top
